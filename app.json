{
  "expo": {
    "icon": "./media/App-Icon.png",
    "name": "Pocket Tour 2",
    "slug": "tennis-scorekeeper",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pockettour2.tennisscorekeeper"
    },
    "android": {
      "package": "com.pockettour2.tennisscorekeeper"
    },
    "plugins": [
      "expo-asset",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Pocket Tour 2 to access your photos to add images to players, matches, and tournaments.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "668d1fe7-8178-418d-8ffb-9e2b208eb301"
      }
    },
    "owner": "mustafasid0124"
  }
}
